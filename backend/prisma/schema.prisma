// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Folder {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  parentId  Int?      @map("parent_id")
  createdBy String   @default("-") @map("created_by") @db.VarChar(255)
  // Relations
  parent    Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]  @relation("FolderHierarchy")
  documents Document[]

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  // Indexes
  @@index([parentId])
  @@index([name])  // Add index for searching folders by name
  @@map("folders")  // Use plural table names (convention)
  @@index([createdBy])
}

model Document {
  id          Int      @id @default(autoincrement())
  folderId    Int?     @map("folder_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  fileName    String?  @map("file_name") @db.VarChar(255)
  mimeType    String?  @map("mime_type") @db.VarChar(100)
  sizeBytes   Int      @default(0) @map("size_bytes")
  createdBy   String   @default("-") @map("created_by") @db.VarChar(255)

  // Relations
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Indexes
  @@index([folderId])
  @@index([title])      // For search by title
  @@index([createdBy])    // For search by createdBy
  @@index([createdAt])  // For sorting by date
  @@map("documents")    // Use plural table names
}
